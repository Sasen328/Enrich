# ============================================================
#  ProspectSA — Environment Variables
#  Copy this file to .env and fill in your values.
#
#  Usage:
#    cp .env.docker .env
#    # Edit .env with your keys
#    docker compose up --build
#
#  REQUIRED: At minimum set ANTHROPIC_API_KEY
#  OPTIONAL: All other keys unlock additional features
# ============================================================

# ── Database (auto-managed by docker-compose — change password if desired) ───
POSTGRES_PASSWORD=prospectsa_secret_change_me

# ── Security ─────────────────────────────────────────────────────────────────
# Uncomment to require bearer token on all API calls
# API_TOKEN=your_random_secret_token_here
# FRONTEND_ORIGIN=http://localhost:3000

# ── AI Providers ─────────────────────────────────────────────────────────────
# REQUIRED — Powers OrcEngine research, Lead Factory, enrichment, Masaar
ANTHROPIC_API_KEY=sk-ant-...

# Powers Nexus Tier 3 synthesis, OrcEngine fallback
OPENAI_API_KEY=sk-...

# Powers SA Market profiles, bilingual generation, OrcEngine news
GEMINI_API_KEY=AIza...

# Powers Nexus Tier 1 (DeepSeek, Llama, Qwen) — cheap extraction.
# Combine with NEXUS_PREFER_FREE_MODELS=true to route every LLM call
# through OpenRouter :free model variants first (zero cost, rate-limited).
# Get key at: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...
NEXUS_PREFER_FREE_MODELS=true

# Powers fast extraction (800 tok/s, near-free)
# Get key at: https://console.groq.com
GROQ_API_KEY=gsk_...

# Powers real-time web search in Signal Intelligence
# Get key at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# Free-tier preferred web-search backend (1000 queries/month dev tier).
# Used by lib/free-search.ts as Tavily → SearXNG → Google waterfall.
# Get key at: https://tavily.com
TAVILY_API_KEY=tvly-dev-...

# Optional: self-hosted SearXNG endpoint(s) for the search fallback.
# SEARXNG_URL=https://searx.be
# SEARXNG_INSTANCES=https://searx.be,https://search.brave4u.com

# Powers Hugging Face model inference
HUGGING_FACE_API_KEY=hf_...

# ── Contact Data APIs (optional — enriches lead emails/phones) ───────────────
APOLLO_API_KEY=
APOLLO_CLIENT_ID=
APOLLO_CLIENT_SECRET=
APOLLO_ACCESS_TOKEN=
EXPLORIUM_API_KEY=
HUNTER_API_KEY=
WAPPALYZER_API_KEY=

# ── AI-Integrations proxy (optional — corporate gateway in front of OpenAI) ──
# When set, lib/config/env.ts routes OpenAI traffic through these instead of
# the public OpenAI endpoint. Leave blank for direct OpenAI.
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_BASE_URL=
OPENAI_BASE_URL=

# ── Local LLM (optional — offline fallback via Ollama) ───────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Perplexity controls ──────────────────────────────────────────────────────
# Set DISABLE_PERPLEXITY=true to force-disable Perplexity even when key set.
DISABLE_PERPLEXITY=

# ── Free-search backends (optional) ──────────────────────────────────────────
# Tavily is already wired above; these add SearXNG as the secondary fallback.
SEARXNG_URL=
SEARXNG_INSTANCES=
FREE_SEARCH_USER_AGENT=

# ── Chromium path override (only needed on Nix / non-standard installs) ──────
CHROMIUM_EXECUTABLE_PATH=

# ── Proxy Providers (optional — enables stealth scraping rotation) ────────────
# All scraping works without proxies — add these for CAPTCHA-heavy targets.
# Master toggle: leave NEXUS_PROXY_ENABLED=false unless you have proxy creds.
NEXUS_PROXY_ENABLED=false
WEBSHARE_PROXY_LIST=
IPROYAL_USER=
IPROYAL_PASS=
IPROYAL_ENDPOINT=
LUNAPROXY_USER=
LUNAPROXY_PASS=
LUNAPROXY_ENDPOINT=
SIMPLYNODE_USER=
SIMPLYNODE_PASS=
SIMPLYNODE_ENDPOINT=

# ── CAPTCHA Solvers (optional — needed for mc.gov.sa CR lookups) ─────────────
# Master toggle: leave NEXUS_CAPTCHA_ENABLED=false unless you have a solver.
NEXUS_CAPTCHA_ENABLED=false
NOPECHA_API_KEY=
AZCAPTCHA_API_KEY=
CAPMONSTER_API_KEY=
DEATHBYCAPTCHA_USER=
DEATHBYCAPTCHA_PASS=

# ── Activepieces (optional — post-pipeline webhook automation) ────────────────
ACTIVEPIECES_URL=
ACTIVEPIECES_API_KEY=
ACTIVEPIECES_FLOW_BUILDER=
ACTIVEPIECES_FLOW_LEAD_FACTORY=
ACTIVEPIECES_FLOW_MASAAR=
ACTIVEPIECES_FLOW_PROSPENGINE=
ACTIVEPIECES_FLOW_SIGNAL_PUSH=

# ── Apify (optional — managed scraping API) ───────────────────────────────────
APIFY_API_KEY=
