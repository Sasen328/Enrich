FROM mcr.microsoft.com/devcontainers/javascript-node:1-24-bookworm

# Install Python 3.11 + uv
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 python3.11-venv python3-pip \
    && rm -rf /var/lib/apt/lists/*

RUN pip install uv --break-system-packages || pip install uv

# Install Playwright system dependencies
RUN npx playwright install-deps chromium || true

# Enable corepack for pnpm
RUN corepack enable && corepack prepare pnpm@9.15.9 --activate

# Set working directory
WORKDIR /workspaces/ProspectSA_Full

# Use node user (matches devcontainer base)
USER node
