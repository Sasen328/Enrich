FROM mcr.microsoft.com/devcontainers/javascript-node:1-24-bookworm

# Install Python 3 + pip (bookworm ships 3.11 as the default python3).
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-venv python3-pip \
    && rm -rf /var/lib/apt/lists/*

# uv is a nice-to-have for the Python Scout sidecar, not required for the
# container to boot — never let its install abort the image build.
RUN python3 -m pip install uv --break-system-packages || python3 -m pip install uv || true

# Install Playwright system dependencies (best-effort).
RUN npx playwright install-deps chromium || true

# Enable corepack for pnpm
RUN corepack enable && corepack prepare pnpm@9.15.9 --activate

# Set working directory
WORKDIR /workspaces/ProspectSA_Full

# Use node user (matches devcontainer base)
USER node
