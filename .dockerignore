# Keep the Docker build context lean.
# Anything listed here is excluded from `COPY . .` in the Dockerfile.

# ── Dependencies (the Dockerfile runs `pnpm install` fresh inside the image) ──
node_modules
**/node_modules
.pnpm-store
.cache
.local

# ── Build outputs (rebuilt inside the image) ──────────────────────────────────
dist
**/dist
build
**/build
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# ── Python venv (installed fresh in /opt/scout-venv) ──────────────────────────
**/.venv
**/__pycache__
*.pyc

# ── Playwright local cache (installed fresh at /ms-playwright) ────────────────
.playwright
**/.playwright-cache
ms-playwright

# ── Git, CI, IDE ──────────────────────────────────────────────────────────────
.git
.github
.gitignore
.gitattributes
.idea
.vscode
.cursor

# ── Local secrets — image reads .env via docker-compose env_file at runtime ──
.env
.env.local
.env.*.local
.env.development
.env.test

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Misc large files we don't need at runtime ─────────────────────────────────
docs
.claude
NEXUS_ENGINE.md
DATABASEBUILDER_FEATURE_DOC.md
SETUP.md
DEPLOY.md
README.md
*.test.ts
*.spec.ts
coverage
